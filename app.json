{
  "expo": {
    "name": "نظام توزيع الغاز",
    "slug": "gas-distribution",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gasdist",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f97316",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gasdist.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f97316"
      },
      "package": "com.gasdist.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "يحتاج التطبيق إلى الكاميرا لمسح رموز QR"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b903fdc1-012b-4b74-9bbf-3d697f181213"
      }
    },
    "owner": "manhl-devs-organization"
  }
}
